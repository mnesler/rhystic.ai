# ── Environment ────────────────────────────────────────────────────────────────
# 'development' uses local OAuth app + allows dev-secret fallback
# 'production'  requires all secrets to be set and fails fast if any are missing
NODE_ENV=development

# ── GitHub OAuth ────────────────────────────────────────────────────────────────
# Create two separate GitHub OAuth Apps — one for local, one for production.
#
# Local app settings:
#   Homepage URL:       http://localhost:5174
#   Callback URL:       http://localhost:3002/auth/callback
#
# Production app settings:
#   Homepage URL:       https://<your-frontend>.run.app
#   Callback URL:       https://<your-backend>.run.app/auth/callback
#
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Full OAuth callback URL — must exactly match what is registered in the GitHub OAuth app
GITHUB_CALLBACK_URL=http://localhost:3002/auth/callback

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Secret used to sign and verify JWTs.
# Generate a strong value for production: openssl rand -hex 64
# In production this MUST be set — the server will refuse to start without it.
JWT_SECRET=

# ── Frontend ────────────────────────────────────────────────────────────────────
# Origin of the frontend app — used for CORS and post-auth redirects.
# Local:      http://localhost:5174
# Production: https://<your-frontend>.run.app
FRONTEND_ORIGIN=http://localhost:5174

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3002

# ── OpenRouter ──────────────────────────────────────────────────────────────────
# API key for LLM calls (intent classification, answer generation, embeddings).
# Get yours at https://openrouter.ai
OPENROUTER_API_KEY=
