{
  "name": "rhystic-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p backend/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch backend/src/index.ts",
    "ingest:scryfall": "tsx backend/src/ingest/scryfall.ts",
    "ingest:spellbook": "tsx backend/src/ingest/spellbook.ts",
    "tag": "tsx backend/src/tagger/tag_set.ts",
    "embed:cards": "node --experimental-sqlite --env-file=./backend/.env backend/dist/assistant/embed.js",
    "assistant": "node --experimental-sqlite --env-file=./backend/.env backend/dist/assistant/cli.js",
    "assistant:serve": "node --experimental-sqlite --env-file=./backend/.env backend/dist/assistant/server.js",
    "assistant:dev": "node --experimental-sqlite --env-file=./backend/.env --import tsx/esm backend/src/assistant/cli.ts"
  },
  "dependencies": {
    "cookie": "^0.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.18.0",
    "better-sqlite3": "^12.6.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
